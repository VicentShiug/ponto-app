generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  MANAGER
  EMPLOYEE
  SUPER_ADMIN
}

enum OvertimeMode {
  OVERTIME
  HOUR_BANK
}

enum CertificateType {
  PARTIAL
  FULL_DAY
}

model User {
  id            String       @id @default(cuid())
  name          String
  email         String       @unique
  passwordHash  String       @map("password_hash")
  role          Role         @default(EMPLOYEE)
  weeklyHours   Float        @default(40) @map("weekly_hours")
  workDays      Int[]        @default([1,2,3,4,5]) @map("work_days")
  overtimeMode  OvertimeMode @default(HOUR_BANK) @map("overtime_mode")
  active        Boolean      @default(true)
  avatarUrl     String?      @map("avatar_url")
  accentColor   String?      @default("default") @map("accent_color")
  theme         String?      @default("light") @map("theme")
  lightIntensity String?    @default("medium") @map("light_intensity")
  darkIntensity  String?    @default("medium") @map("dark_intensity")
  journeyStart       String?  @map("journey_start")
  journeyLunch       String?  @map("journey_lunch")
  journeyLunchReturn String?  @map("journey_lunch_return")
  journeyEnd         String?  @map("journey_end")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  managerId            String?       @map("manager_id")
  manager              User?         @relation("ManagerEmployees", fields: [managerId], references: [id])
  employees            User[]        @relation("ManagerEmployees")

  timeEntries          TimeEntry[]
  hourBankAdjustments  HourBankAdjustment[]  @relation("EmployeeAdjustments")
  managedAdjustments   HourBankAdjustment[]  @relation("ManagerAdjustments")
  actorAuditLogs       AuditLog[]            @relation("ActorLogs")
  targetAuditLogs      AuditLog[]            @relation("TargetLogs")
  certificates         MedicalCertificate[]  @relation("UserCertificates")
  createdCertificates  MedicalCertificate[]  @relation("CreatedCertificates")

  @@map("users")
}

model TimeEntry {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  date      DateTime  @db.Date
  clockIn   DateTime? @map("clock_in")
  lunchOut  DateTime? @map("lunch_out")
  lunchIn   DateTime? @map("lunch_in")
  clockOut  DateTime? @map("clock_out")
  notes     String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@map("time_entries")
}

model HourBankAdjustment {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  managerId  String   @map("manager_id")
  minutes    Int
  reason     String
  createdAt  DateTime @default(now()) @map("created_at")

  user    User @relation("EmployeeAdjustments", fields: [userId], references: [id])
  manager User @relation("ManagerAdjustments", fields: [managerId], references: [id])

  @@map("hour_bank_adjustments")
}

model AuditLog {
  id           String   @id @default(cuid())
  actorId      String   @map("actor_id")
  action       String
  targetUserId String?  @map("target_user_id")
  details      Json
  createdAt    DateTime @default(now()) @map("created_at")

  actor      User  @relation("ActorLogs", fields: [actorId], references: [id])
  targetUser User? @relation("TargetLogs", fields: [targetUserId], references: [id])

  @@map("audit_logs")
}

model MedicalCertificate {
  id          String          @id @default(cuid())
  userId      String          @map("user_id")
  createdById String          @map("created_by_id")
  type        CertificateType
  date        DateTime?       @db.Date
  startDate   DateTime?       @map("start_date") @db.Date
  endDate     DateTime?       @map("end_date") @db.Date
  startTime   String?         @map("start_time")
  endTime     String?         @map("end_time")
  reason      String?
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  user      User @relation("UserCertificates", fields: [userId], references: [id])
  createdBy User @relation("CreatedCertificates", fields: [createdById], references: [id])

  @@map("medical_certificates")
}
